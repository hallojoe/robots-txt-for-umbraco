{
  "HttpResponseHeaders": {
    "Enabled": true,
    "Hosts": {
      "default": {
        "HostName": "localhost:44341",
        "AllowPaths": [],
        "DenyPaths": ["/umbraco" ],
        "Profiles": ["default"]
      },
      "host-1": {
        "HostName": "localhost:44345",
        "AllowPaths": [],
        "DenyPaths": ["/umbraco" ],
        "Profiles": ["default"]
      },
      "host-2": {
        "HostName": "localhost:44346",
        "AllowPaths": [],
        "DenyPaths": ["/umbraco" ],
        "Profiles": ["default"]
      }
    },
    "Profiles": {
      "default": {
        "Enabled": true,
        "Remove": [
          "Server",
          "server",
          "X-Powered-By"
        ],
        "Add": {
          "X-Content-Type-Options": ["nosniff"],
          "X-Frame-Options": ["SAMEORIGIN"],
          "Referrer-Policy": ["strict-origin-when-cross-origin"], 
          "X-Permitted-Cross-Domain-Policies": ["none"],
          "X-XSS-Protection": ["0"],
          "Permissions-Policy": [
            "accelerometer=()", 
            ", camera=()", 
            ", geolocation=()", 
            ", gyroscope=()", 
              ", magnetometer=()", 
            ", microphone=()", 
            ", payment=()", 
            ", usb=()"
          ],
          "Strict-Transport-Security": ["max-age=31536000; includeSubDomains"],
          "Content-Security-Policy": [
            "default-src 'self';",
            "base-uri 'self';",    
            "object-src 'none';",
            "frame-ancestors 'self';",
            "form-action 'self';",
            "script-src 'self' https://host1.local;",
            "style-src 'self' 'unsafe-inline';",
            "img-src 'self' data: https:;",
            "font-src 'self' data:;",
            "connect-src 'self';",
            "upgrade-insecure-requests"
          ]
        }
      },
      "strict": {
        "Enabled": true,
        "Add": {
          "X-Frame-Options": ["DENY"],
          "Content-Security-Policy": [
            "frame-ancestors 'none'",
            "script-src 'self' https://safe-website.com"
          ]
        }
      }
    }
  }
}
