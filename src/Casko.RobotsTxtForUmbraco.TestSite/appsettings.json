      },
      "Hosting": {
        "Debug": false
      },
      "Runtime": {
        "Mode": "Development"
      },
      "Imaging": {
        "HMACSecretKey": "bSj9vkxtC3o1tJ7\u002ByQV7LBxswzn8EOy6j7Z4t5ZEGzHjrp\u002BuXLImUVd2rI7\u002BWG\u002B0BJYnlgy4Gh1SMxZUHhf6GQ=="
      }
    }
  },
  "RobotsTxt": {
    "Enabled": true,
    "RewritesEnabled": true,
    "RootNodeSearchLevel": 0,
    "ExcludingUrlPropertyAlias": "umbracoNaviHide",
    "ExcludingUrlPropertyValue": "1",
    "HostingDocumentTypeAliases": ["homePage"],
    "Files": {
      "default": {
        "DisallowScanEnabled": true,
        "HostName": "",
        "Sitemaps": [],
        "UserAgents": {
          "*": {
            "Disallow": [
              "/"
            ],
            "Allow": []
          }
