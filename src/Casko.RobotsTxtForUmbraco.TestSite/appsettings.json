      },
      "host-1": {
        "DisallowScanEnabled": true,
        "HostName": "https://localhost:44345",
        "Sitemaps": [
          "https://localhost:44345/sitemap45.xml"
        ],
        "UserAgents": {
          "*": {
            "Disallow": [
              "/private"
            ],
            "Allow": []
