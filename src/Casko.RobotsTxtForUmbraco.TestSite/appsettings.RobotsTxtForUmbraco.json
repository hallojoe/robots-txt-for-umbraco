{
  "RobotsTxt": {
    "Enabled": true,
    "RewritesEnabled": true,
    "DefaultHost": "",
    "Bindings": {
      "": {
        "Include": ["robots.txt"]
      },
      "localhost:44345": {
        "Url": "https://real-url.com",
        "Sitemaps": ["sitemapindex-da.xml", "sitemapindex-en.xml"],
        "Include": ["robots.ai-bots.txt", "robots.defaults.txt"]
      },
      "localhost:44346": {
        "Url": "",
        "Sitemaps": ["sitemapindex-da.xml", "sitemapindex-en.xml"],
        "Include": ["robots.ai-bots.txt", "robots.defaults.txt"]
      }
    },
    "Hosts": {
      "default": {
        "Profiles": [
          "disallow-all"
        ]
      }
    },
    "Profiles": {
      "disallow-all": {
        "UserAgents": {
          "*": {
            "Disallow": [
              "/"
            ]
          }
        }
      }
    },
    "Storage": {
      "RefreshStaleAfterSeconds": 3600,
      "BackgroundJob": {
        "Enabled": true,
        "IntervalSeconds": 3600,
        "RefreshJobDelayInSeconds": 30
      }
    }
  }
}
